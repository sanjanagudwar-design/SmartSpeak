<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SpeakSmart — Your AI English Coach</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700;9..144,900&family=Sora:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════
   TOKENS
   Palette: deep indigo ink + warm coral signal + teal success.
   No yellow anywhere. Solid colors only — no gradients on surfaces.
═══════════════════════════════════════ */
:root {
  /* DARK */
  --bg:        #0E1320;
  --surface:   #161D2E;
  --card:      #1C2438;
  --border:    #2A3450;
  --border2:   #3B4768;

  --ink:       #5B7FFF;   /* primary signal — indigo-blue, replaces amber */
  --ink-dim:   rgba(91,127,255,0.14);
  --ink-soft:  #8AA3FF;

  --coral:     #FF6B5B;
  --coral-dim: rgba(255,107,91,0.14);
  --teal:      #1F9E83;
  --teal-soft: #2FC4A3;
  --teal-dim:  rgba(47,196,163,0.14);
  --plum:      #9B7BFF;
  --plum-dim:  rgba(155,123,255,0.14);

  --text:      #EEF1FA;
  --text2:     #9CA6C4;
  --text3:     #62698A;

  --nav-bg:    rgba(14,19,32,0.92);
  --input-bg:  #161D2E;

  --on-ink:    #0B1020;

  --shadow:    0 4px 24px rgba(0,0,0,0.45);
  --shadow-lg: 0 16px 48px rgba(0,0,0,0.55);
}

[data-theme="light"] {
  --bg:        #F4F2EC;
  --surface:   #FFFFFF;
  --card:      #ECE9DF;
  --border:    #DCD8CC;
  --border2:   #C2BDAC;

  --ink:       #36499E;
  --ink-dim:   rgba(54,73,158,0.10);
  --ink-soft:  #4A5EBE;

  --coral:     #D6492F;
  --coral-dim: rgba(214,73,47,0.10);
  --teal:      #16735F;
  --teal-soft: #1B8C73;
  --teal-dim:  rgba(27,140,115,0.10);
  --plum:      #6E50C9;
  --plum-dim:  rgba(110,80,201,0.10);

  --text:      #1B1E2C;
  --text2:     #4D5168;
  --text3:     #8A8C9E;

  --nav-bg:    rgba(244,242,236,0.92);
  --input-bg:  #FFFFFF;

  --on-ink:    #FFFFFF;

  --shadow:    0 4px 24px rgba(30,28,20,0.08);
  --shadow-lg: 0 16px 48px rgba(30,28,20,0.12);
}

/* ═══════════════════════════════════════
   RESET & BASE
═══════════════════════════════════════ */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Sora', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
  transition: background 0.3s, color 0.3s;
}

::selection { background: var(--ink-dim); color: var(--ink-soft); }

/* ═══════════════════════════════════════
   SCREENS
═══════════════════════════════════════ */
.screen { display: none; min-height: 100vh; flex-direction: column; }
.screen.active { display: flex; }

/* ═══════════════════════════════════════
   NAV
═══════════════════════════════════════ */
.nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px;
  background: var(--nav-bg);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  position: sticky; top: 0; z-index: 200;
  gap: 8px;
}

.nav-logo {
  font-family: 'Fraunces', serif;
  font-size: 1.2rem;
  font-weight: 700;
  font-style: italic;
  color: var(--text);
  letter-spacing: -0.3px;
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  background: none;
  border: none;
  padding: 0;
}

.nav-logo .logo-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--coral);
  display: inline-block;
  animation: dotBounce 2.4s ease-in-out infinite;
}

@keyframes dotBounce {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-4px); }
}

.nav-right { display: flex; align-items: center; gap: 7px; }

.nav-pill {
  background: var(--card);
  border: 1px solid var(--border);
  color: var(--text2);
  padding: 5px 11px;
  border-radius: 20px;
  font-size: 0.7rem;
  font-weight: 600;
  cursor: pointer;
  letter-spacing: 0.01em;
  transition: all 0.2s;
  font-family: 'Sora', sans-serif;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.nav-pill:hover { border-color: var(--border2); color: var(--text); }

/* icon-only square buttons used in nav (theme / lang / profile) */
.nav-icon-btn {
  width: 34px; height: 34px;
  border-radius: 10px;
  background: var(--card);
  border: 1px solid var(--border);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.95rem;
  transition: all 0.2s;
  color: var(--text2);
  flex-shrink: 0;
}
.nav-icon-btn:hover { border-color: var(--ink); color: var(--ink-soft); }

/* ═══════════════════════════════════════
   LANGUAGE SWITCHER (popover, available everywhere)
═══════════════════════════════════════ */
.lang-pop-wrap { position: relative; }
.lang-pop {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  box-shadow: var(--shadow-lg);
  padding: 8px;
  width: 190px;
  z-index: 300;
  display: none;
}
.lang-pop.open { display: block; }
.lang-pop-label {
  font-size: 0.62rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text3);
  padding: 6px 8px 8px;
}
.lang-pop-item {
  display: flex;
  align-items: center;
  gap: 9px;
  width: 100%;
  background: none;
  border: none;
  text-align: left;
  padding: 9px 8px;
  border-radius: 9px;
  font-size: 0.84rem;
  font-weight: 600;
  color: var(--text);
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  transition: background 0.15s;
}
.lang-pop-item:hover { background: var(--card); }
.lang-pop-item.active { color: var(--ink-soft); background: var(--ink-dim); }
.lang-pop-item .flag { font-size: 1.05rem; width: 20px; text-align:center; }
.lang-pop-backdrop {
  position: fixed; inset: 0; z-index: 290; display: none;
}
.lang-pop-backdrop.open { display: block; }

/* ═══════════════════════════════════════
   LANDING — HERO
═══════════════════════════════════════ */
#landing {
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 56px 24px 70px;
  position: relative;
  overflow: hidden;
}

/* Decorative solid shape — no blurred gradient blobs, a single quiet panel instead */
.hero-panel-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 340px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  z-index: 0;
}

.landing-inner { position: relative; z-index: 1; max-width: 480px; width: 100%; margin: 0 auto; }

/* Logo mark */
.hero-logo-mark {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 30px;
  justify-content: center;
}

.logo-icon {
  width: 60px; height: 60px;
  background: var(--ink);
  border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.6rem;
  box-shadow: 0 8px 22px rgba(91,127,255,0.32);
}

.logo-text-block { text-align: left; }
.logo-name {
  font-family: 'Fraunces', serif;
  font-size: 1.85rem;
  font-weight: 700;
  font-style: italic;
  color: var(--text);
  line-height: 1;
  letter-spacing: -0.5px;
}
.logo-tagline {
  font-size: 0.68rem;
  color: var(--text3);
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-top: 4px;
  font-family: 'Sora', sans-serif;
}

/* Hero headline */
.hero-headline {
  font-family: 'Fraunces', serif;
  font-size: clamp(2rem, 8vw, 3.2rem);
  font-weight: 600;
  line-height: 1.08;
  letter-spacing: -1px;
  color: var(--text);
  margin-bottom: 8px;
}

.hero-headline em {
  font-style: italic;
  font-weight: 700;
  color: var(--ink-soft);
  position: relative;
  display: inline-block;
}

/* solid underline mark instead of squiggle */
.hero-headline em::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 2px; right: 2px;
  height: 8px;
  background: var(--coral);
  opacity: 0.28;
  border-radius: 4px;
  z-index: -1;
}

.hero-sub {
  font-size: 0.95rem;
  color: var(--text2);
  line-height: 1.75;
  margin: 18px auto 28px;
  max-width: 360px;
}

/* rotating quote chip — solid border, no glow */
.floating-word {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--teal-dim);
  border: 1px solid var(--teal-soft);
  color: var(--teal-soft);
  padding: 8px 18px;
  border-radius: 10px;
  font-size: 0.78rem;
  font-weight: 600;
  margin-bottom: 36px;
  letter-spacing: 0.01em;
  font-family: 'Sora', sans-serif;
  transition: opacity 0.3s;
}

/* CTA */
.btn-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--ink);
  color: #fff;
  border: none;
  padding: 16px 34px;
  border-radius: 13px;
  font-size: 0.95rem;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  letter-spacing: 0.01em;
  transition: all 0.2s;
  box-shadow: 0 6px 18px rgba(91,127,255,0.32);
}
.btn-cta:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(91,127,255,0.4); }
.btn-cta:active { transform: translateY(0); }

.btn-cta .arrow { transition: transform 0.2s; }
.btn-cta:hover .arrow { transform: translateX(4px); }

/* Trust pills — solid fills, distinct colors, no dot+glow combo */
.trust-row {
  display: flex;
  gap: 9px;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 34px;
}

.trust-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 7px 13px;
  border-radius: 9px;
  font-size: 0.74rem;
  color: var(--text2);
  font-weight: 600;
}
.trust-pill .dot { width: 6px; height: 6px; border-radius: 50%; }

/* tiny footer credit row on landing */
.landing-footnote {
  margin-top: 40px;
  font-size: 0.7rem;
  color: var(--text3);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

/* ═══════════════════════════════════════
   INTRO — LANGUAGE PICK
═══════════════════════════════════════ */
#intro {
  align-items: center;
  justify-content: flex-start;
  padding: 0;
}

.intro-inner {
  width: 100%; max-width: 480px;
  margin: 0 auto;
  padding: 36px 24px 80px;
}

.step-eyebrow {
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--text3);
  margin-bottom: 12px;
  font-family: 'JetBrains Mono', monospace;
}

.step-title {
  font-family: 'Fraunces', serif;
  font-size: 1.75rem;
  font-weight: 600;
  line-height: 1.15;
  letter-spacing: -0.5px;
  margin-bottom: 8px;
}

.step-sub {
  font-size: 0.87rem;
  color: var(--text2);
  margin-bottom: 26px;
  line-height: 1.6;
}

.lang-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10px;
  margin-bottom: 30px;
}

.lang-btn {
  background: var(--surface);
  border: 1.5px solid var(--border);
  color: var(--text2);
  padding: 16px 8px;
  border-radius: 14px;
  font-size: 0.81rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.18s;
  font-family: 'Sora', sans-serif;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  line-height: 1.2;
}
.lang-btn .flag { font-size: 1.4rem; }
.lang-btn:hover { border-color: var(--ink); color: var(--text); background: var(--ink-dim); }
.lang-btn.selected { border-color: var(--ink); color: var(--ink-soft); background: var(--ink-dim); }

/* ═══════════════════════════════════════
   LEVEL TEST
═══════════════════════════════════════ */
#leveltest { align-items: center; }

.test-wrap {
  width: 100%; max-width: 520px;
  margin: 0 auto;
  padding: 26px 24px 60px;
}

.test-header { margin-bottom: 26px; }

.prog-track {
  height: 4px;
  background: var(--border);
  border-radius: 4px;
  margin-bottom: 26px;
  overflow: hidden;
}
.prog-fill {
  height: 100%;
  background: var(--ink);
  border-radius: 4px;
  transition: width 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.q-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 26px 22px;
  position: relative;
  overflow: hidden;
}

.q-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--ink);
}

.q-num {
  font-size: 0.66rem;
  color: var(--ink-soft);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  margin-bottom: 12px;
  font-family: 'JetBrains Mono', monospace;
}

.q-text {
  font-family: 'Fraunces', serif;
  font-size: 1.08rem;
  font-weight: 600;
  margin-bottom: 20px;
  line-height: 1.45;
  color: var(--text);
}

.opts { display: flex; flex-direction: column; gap: 9px; }

.opt-btn {
  background: var(--card);
  border: 1.5px solid var(--border);
  color: var(--text);
  padding: 13px 16px;
  border-radius: 12px;
  font-size: 0.85rem;
  cursor: pointer;
  text-align: left;
  transition: all 0.16s;
  font-family: 'Sora', sans-serif;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 12px;
}

.opt-letter {
  width: 26px; height: 26px;
  border-radius: 8px;
  background: var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.7rem;
  font-weight: 700;
  flex-shrink: 0;
  font-family: 'JetBrains Mono', monospace;
  color: var(--text3);
  transition: all 0.16s;
}

.opt-btn:hover { border-color: var(--ink); background: var(--ink-dim); }
.opt-btn:hover .opt-letter { background: var(--ink-dim); color: var(--ink-soft); }

.opt-btn.correct { border-color: var(--teal-soft); background: var(--teal-dim); color: var(--teal-soft); }
.opt-btn.correct .opt-letter { background: var(--teal-dim); color: var(--teal-soft); }
.opt-btn.wrong { border-color: var(--coral); background: var(--coral-dim); color: var(--coral); }
.opt-btn.wrong .opt-letter { background: var(--coral-dim); color: var(--coral); }

/* result */
.result-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 34px 24px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.result-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; height: 3px;
  background: var(--teal-soft);
}
.result-emoji { font-size: 3.2rem; margin-bottom: 14px; display: block; animation: bounceIn 0.45s cubic-bezier(0.34,1.56,0.64,1); }
@keyframes bounceIn { 0% { transform: scale(0.5); opacity:0; } 100% { transform: scale(1); opacity:1; } }
.result-level {
  font-family: 'Fraunces', serif;
  font-size: 2.1rem;
  font-weight: 700;
  color: var(--ink-soft);
  margin-bottom: 6px;
}
.result-score { font-size: 0.88rem; color: var(--teal-soft); font-weight: 700; margin-bottom: 12px; font-family: 'JetBrains Mono', monospace; }
.result-desc { color: var(--text2); font-size: 0.85rem; line-height: 1.7; margin-bottom: 22px; }

/* ═══════════════════════════════════════
   DASHBOARD
═══════════════════════════════════════ */
#dashboard { padding: 0; }

.dash-hero {
  padding: 26px 20px 22px;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
}

.dash-hello { font-size: 0.78rem; color: var(--text3); margin-bottom: 4px; font-weight: 600; }

.dash-title {
  font-family: 'Fraunces', serif;
  font-size: 1.5rem;
  font-weight: 600;
  letter-spacing: -0.3px;
  margin-bottom: 16px;
}

.meta-row { display: flex; gap: 8px; flex-wrap: wrap; }

.meta-chip {
  display: flex; align-items: center; gap: 6px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 6px 12px;
  font-size: 0.74rem;
  color: var(--text2);
  font-weight: 600;
  font-family: 'JetBrains Mono', monospace;
}
.meta-chip b { color: var(--text); font-family: 'Sora', sans-serif; }

/* WOTD strip */
.wotd-strip {
  margin: 16px 20px 0;
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 3px solid var(--ink);
  border-radius: 12px;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  transition: border-color 0.2s;
}
.wotd-strip:hover { border-color: var(--ink); }
.wotd-label { font-size: 0.63rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-soft); margin-bottom: 2px; font-family: 'JetBrains Mono', monospace; }
.wotd-word { font-family: 'Fraunces', serif; font-size: 1.05rem; font-weight: 600; color: var(--text); }
.wotd-def { font-size: 0.75rem; color: var(--text2); margin-top: 1px; }
.wotd-icon { font-size: 1.3rem; flex-shrink: 0; }

/* quick-access row: profile / tracker / tasks */
.quick-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10px;
  margin: 16px 20px 0;
}
.quick-item {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 14px 8px;
  text-align: center;
  cursor: pointer;
  transition: all 0.18s;
}
.quick-item:hover { transform: translateY(-2px); border-color: var(--border2); box-shadow: var(--shadow); }
.quick-item .qi-icon {
  width: 38px; height: 38px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem;
  margin: 0 auto 8px;
}
.quick-item .qi-label { font-size: 0.72rem; font-weight: 700; color: var(--text); }
.quick-item .qi-sub { font-size: 0.62rem; color: var(--text3); margin-top: 1px; font-family: 'JetBrains Mono', monospace; }

/* CARDS */
.section-pad { padding: 20px 20px 120px; }
.section-eyebrow {
  font-size: 0.64rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--text3);
  margin-bottom: 14px;
  padding-left: 2px;
  font-family: 'JetBrains Mono', monospace;
}

.cards-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

.feat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 20px 16px;
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
  text-decoration: none;
}

.feat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); }

.card-stripe {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
}

.feat-card.c-ink .card-stripe { background: var(--ink); }
.feat-card.c-teal .card-stripe { background: var(--teal-soft); }
.feat-card.c-coral .card-stripe { background: var(--coral); }
.feat-card.c-plum .card-stripe { background: var(--plum); }

.feat-card.c-ink:hover { border-color: var(--ink); }
.feat-card.c-teal:hover { border-color: var(--teal-soft); }
.feat-card.c-coral:hover { border-color: var(--coral); }
.feat-card.c-plum:hover { border-color: var(--plum); }

.card-icon {
  width: 40px; height: 40px;
  border-radius: 11px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem;
  margin-bottom: 14px;
}
.c-ink .card-icon { background: var(--ink-dim); }
.c-teal .card-icon { background: var(--teal-dim); }
.c-coral .card-icon { background: var(--coral-dim); }
.c-plum .card-icon { background: var(--plum-dim); }

.card-name {
  font-family: 'Sora', sans-serif;
  font-size: 0.89rem;
  font-weight: 700;
  margin-bottom: 4px;
  color: var(--text);
}
.card-hint { font-size: 0.71rem; color: var(--text3); line-height: 1.4; }

.new-tag {
  position: absolute;
  top: 14px; right: 12px;
  background: var(--coral);
  color: #fff;
  font-size: 0.55rem;
  font-weight: 800;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  padding: 2px 7px;
  border-radius: 4px;
}

/* daily tip */
.tip-card {
  margin-top: 12px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 18px;
}
.tip-label { font-size: 0.63rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--teal-soft); margin-bottom: 8px; font-family: 'JetBrains Mono', monospace; }
.tip-text { font-size: 0.84rem; line-height: 1.7; color: var(--text2); }
.tip-text strong { color: var(--text); }

/* ═══════════════════════════════════════
   FEATURE SCREENS (shared)
═══════════════════════════════════════ */
.screen-wrap { padding: 22px 20px 130px; max-width: 580px; margin: 0 auto; width: 100%; }

.screen-h {
  font-family: 'Fraunces', serif;
  font-size: 1.28rem;
  font-weight: 600;
  margin-bottom: 4px;
  color: var(--text);
}
.screen-sh { color: var(--text2); font-size: 0.81rem; margin-bottom: 22px; line-height: 1.5; }

/* MIC ZONE */
.mic-zone {
  background: var(--surface);
  border: 2px dashed var(--border);
  border-radius: 20px;
  padding: 38px 20px;
  text-align: center;
  margin-bottom: 16px;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}
.mic-zone.on { border-color: var(--coral); border-style: solid; }

.big-mic {
  width: 80px; height: 80px;
  border-radius: 50%;
  background: var(--ink);
  border: none;
  font-size: 1.9rem;
  cursor: pointer;
  margin: 0 auto 16px;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6px 18px rgba(91,127,255,0.36);
  transition: all 0.2s;
  position: relative; z-index: 1;
}
.big-mic:hover { transform: scale(1.06); box-shadow: 0 10px 26px rgba(91,127,255,0.46); }
.big-mic.on { background: var(--coral); box-shadow: 0 6px 18px rgba(255,107,91,0.46); animation: micPulse 1.2s ease-in-out infinite; }
@keyframes micPulse { 0%,100%{transform:scale(1);} 50%{transform:scale(1.06);} }

.mic-status { color: var(--text3); font-size: 0.82rem; margin-bottom: 8px; position: relative; z-index: 1; }
.mic-output { font-size: 0.94rem; color: var(--text); font-style: italic; min-height: 22px; position: relative; z-index: 1; line-height: 1.5; }

/* AI speaking */
.ai-speaking {
  display: none;
  align-items: center;
  gap: 10px;
  background: var(--teal-dim);
  border: 1px solid var(--teal-soft);
  border-radius: 10px;
  padding: 10px 16px;
  margin-bottom: 14px;
  font-size: 0.8rem;
  color: var(--teal-soft);
  font-weight: 600;
}
.ai-speaking.visible { display: flex; }

.wave-bars { display: flex; align-items: center; gap: 2.5px; height: 18px; }
.wave-bar { width: 3px; background: var(--teal-soft); border-radius: 2px; animation: waveA 0.9s ease-in-out infinite; }
.wave-bar:nth-child(1){height:6px; animation-delay:0s;}
.wave-bar:nth-child(2){height:14px; animation-delay:0.1s;}
.wave-bar:nth-child(3){height:10px; animation-delay:0.2s;}
.wave-bar:nth-child(4){height:18px; animation-delay:0.3s;}
.wave-bar:nth-child(5){height:8px; animation-delay:0.4s;}
@keyframes waveA { 0%,100%{transform:scaleY(0.35);} 50%{transform:scaleY(1);} }

/* score / feedback */
.feedback-box {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 18px;
  margin-bottom: 10px;
}
.fb-label { font-size: 0.66rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text3); margin-bottom: 8px; font-family: 'JetBrains Mono', monospace; }
.fb-text { font-size: 0.87rem; line-height: 1.7; color: var(--text); }

.score-row { display: flex; align-items: center; gap: 14px; margin-bottom: 14px; }

.score-ring {
  width: 60px; height: 60px;
  border-radius: 50%;
  background: conic-gradient(var(--teal-soft) 0deg, var(--border) 0deg);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.score-inner {
  width: 45px; height: 45px;
  border-radius: 50%;
  background: var(--surface);
  display: flex; align-items: center; justify-content: center;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.86rem;
  font-weight: 600;
  color: var(--teal-soft);
}
.score-info b { font-size: 0.94rem; display: block; margin-bottom: 2px; color: var(--text); }
.score-info span { font-size: 0.75rem; color: var(--text3); }

/* CHAT */
.chat-wrap { padding: 16px 20px 130px; max-width: 580px; margin: 0 auto; width: 100%; }

.job-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }

.job-btn {
  background: var(--surface);
  border: 1.5px solid var(--border);
  color: var(--text2);
  padding: 16px 10px;
  border-radius: 14px;
  font-size: 0.81rem;
  font-weight: 600;
  cursor: pointer;
  text-align: center;
  transition: all 0.18s;
  font-family: 'Sora', sans-serif;
}
.job-btn:hover { border-color: var(--coral); color: var(--coral); background: var(--coral-dim); }

.chat-box {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 16px;
  min-height: 300px;
  max-height: 420px;
  overflow-y: auto;
  margin-bottom: 12px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  scroll-behavior: smooth;
}

.msg { display: flex; gap: 10px; align-items: flex-start; }
.msg.ai { flex-direction: row; }
.msg.user { flex-direction: row-reverse; }

.msg-av {
  width: 30px; height: 30px;
  border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.85rem;
  flex-shrink: 0;
}
.msg.ai .msg-av { background: var(--ink-dim); border: 1px solid var(--ink); }
.msg.user .msg-av { background: var(--teal-dim); border: 1px solid var(--teal-soft); }

.msg-bub {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 10px 14px;
  font-size: 0.83rem;
  line-height: 1.65;
  max-width: 80%;
  color: var(--text);
}
.msg.user .msg-bub { background: var(--teal-dim); border-color: var(--teal-soft); }

/* input bar */
.input-bar {
  display: flex;
  gap: 8px;
  position: fixed;
  bottom: 68px;
  left: 50%;
  transform: translateX(-50%);
  width: calc(100% - 32px);
  max-width: 548px;
  background: var(--nav-bg);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 8px;
  z-index: 99;
}

.txt-input {
  flex: 1;
  background: var(--input-bg);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 10px 14px;
  border-radius: 9px;
  font-size: 0.87rem;
  font-family: 'Sora', sans-serif;
  outline: none;
  transition: border-color 0.2s;
}
.txt-input::placeholder { color: var(--text3); }
.txt-input:focus { border-color: var(--ink); }

.send-btn {
  background: var(--ink);
  border: none;
  color: #fff;
  width: 40px; height: 40px;
  border-radius: 9px;
  cursor: pointer;
  font-size: 0.9rem;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  font-weight: 700;
  transition: all 0.2s;
}
.send-btn:hover { opacity: 0.85; }

/* SCENARIOS */
.scenario-item {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 18px;
  margin-bottom: 10px;
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
  padding-right: 40px;
}
.scenario-item:hover { border-color: var(--ink); transform: translateX(3px); }
.scenario-item::after { content: '→'; position: absolute; right: 18px; top: 50%; transform: translateY(-50%); color: var(--text3); font-size: 1rem; }
.sc-tag { font-size: 0.66rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-soft); margin-bottom: 5px; font-family: 'JetBrains Mono', monospace; }
.sc-title { font-weight: 700; font-size: 0.92rem; margin-bottom: 3px; color: var(--text); }
.sc-desc { font-size: 0.76rem; color: var(--text3); line-height: 1.4; }

/* ═══════════════════════════════════════
   BOTTOM NAV
═══════════════════════════════════════ */
.bottom-nav {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--nav-bg);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 1px solid var(--border);
  display: none;
  justify-content: space-around;
  padding: 7px 0 max(12px, env(safe-area-inset-bottom));
  z-index: 200;
}
.bottom-nav.show { display: flex; }

.bnav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  cursor: pointer;
  padding: 5px 10px;
  border-radius: 10px;
  transition: all 0.2s;
  background: none;
  border: none;
  color: var(--text3);
  font-family: 'Sora', sans-serif;
}
.bnav-item.on { color: var(--ink-soft); }
.bnav-item .ico { font-size: 1.1rem; }
.bnav-item .lbl { font-size: 0.56rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; }

/* ═══════════════════════════════════════
   LOADING DOTS
═══════════════════════════════════════ */
.loading-dots { display: flex; align-items: center; gap: 8px; color: var(--text3); font-size: 0.81rem; }
.dot-row span {
  display: inline-block;
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--ink);
  animation: dotBob 1.2s ease-in-out infinite;
}
.dot-row span:nth-child(2){animation-delay:0.15s;}
.dot-row span:nth-child(3){animation-delay:0.3s;}
@keyframes dotBob {
  0%,80%,100%{transform:translateY(0);opacity:0.3;}
  40%{transform:translateY(-5px);opacity:1;}
}

/* ═══════════════════════════════════════
   UTILS
═══════════════════════════════════════ */
.hidden { display: none !important; }
.mt12 { margin-top: 12px; }
.mt20 { margin-top: 20px; }

.back-row { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }

.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: var(--ink);
  color: #fff;
  border: none;
  padding: 14px 32px;
  border-radius: 12px;
  font-size: 0.92rem;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  transition: all 0.2s;
  box-shadow: 0 4px 14px rgba(91,127,255,0.3);
}
.btn-primary:hover { opacity: 0.92; transform: translateY(-1px); }
.btn-outline {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: none;
  color: var(--text2);
  border: 1px solid var(--border);
  padding: 12px 24px;
  border-radius: 12px;
  font-size: 0.87rem;
  font-weight: 600;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  transition: all 0.2s;
}
.btn-outline:hover { border-color: var(--border2); color: var(--text); }

.btn-danger-outline {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: none;
  color: var(--coral);
  border: 1px solid var(--coral);
  padding: 12px 24px;
  border-radius: 12px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  font-family: 'Sora', sans-serif;
  transition: all 0.2s;
}
.btn-danger-outline:hover { background: var(--coral-dim); }

/* confetti burst */
.confetti-burst { position: fixed; pointer-events: none; z-index: 9998; }
.confetti-piece { position: absolute; width: 8px; height: 8px; border-radius: 2px; animation: confettiFall 1.2s ease-out forwards; }
@keyframes confettiFall {
  0% { transform: translateY(0) rotate(0deg); opacity: 1; }
  100% { transform: translateY(120px) rotate(540deg); opacity: 0; }
}

/* progress steps */
.step-dots { display: flex; gap: 6px; margin-bottom: 26px; }
.step-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--border); transition: all 0.3s; }
.step-dot.done { background: var(--ink); transform: scale(1.2); }

/* ═══════════════════════════════════════
   PROFILE SCREEN
═══════════════════════════════════════ */
.profile-hero {
  padding: 30px 20px 26px;
  text-align: center;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
}
.avatar-wrap { position: relative; display: inline-block; margin-bottom: 14px; }
.avatar-circle {
  width: 84px; height: 84px;
  border-radius: 50%;
  background: var(--ink);
  display: flex; align-items: center; justify-content: center;
  font-size: 2rem;
  color: #fff;
  font-family: 'Fraunces', serif;
  font-weight: 600;
  box-shadow: 0 6px 18px rgba(91,127,255,0.32);
}
.avatar-edit-btn {
  position: absolute;
  bottom: -2px; right: -2px;
  width: 28px; height: 28px;
  border-radius: 50%;
  background: var(--coral);
  border: 2px solid var(--surface);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.72rem;
  cursor: pointer;
  color: #fff;
}
.profile-name {
  font-family: 'Fraunces', serif;
  font-size: 1.3rem;
  font-weight: 600;
  margin-bottom: 3px;
}
.profile-sub { font-size: 0.78rem; color: var(--text3); font-family: 'JetBrains Mono', monospace; }

.profile-stats-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10px;
  margin: 18px 20px 0;
}
.pstat {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 14px 8px;
  text-align: center;
}
.pstat-num { font-family: 'JetBrains Mono', monospace; font-size: 1.15rem; font-weight: 600; color: var(--ink-soft); }
.pstat-lbl { font-size: 0.64rem; color: var(--text3); margin-top: 3px; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600; }

.profile-form {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 20px;
  margin-top: 16px;
}
.field-label {
  font-size: 0.66rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text3);
  margin-bottom: 7px;
  display: block;
  font-family: 'JetBrains Mono', monospace;
}
.field-input {
  width: 100%;
  background: var(--input-bg);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 11px 14px;
  border-radius: 10px;
  font-size: 0.87rem;
  font-family: 'Sora', sans-serif;
  outline: none;
  margin-bottom: 16px;
  transition: border-color 0.2s;
}
.field-input:focus { border-color: var(--ink); }

.goal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 4px; }
.goal-chip {
  background: var(--card);
  border: 1.5px solid var(--border);
  color: var(--text2);
  padding: 10px 8px;
  border-radius: 10px;
  font-size: 0.78rem;
  font-weight: 600;
  cursor: pointer;
  text-align: center;
  transition: all 0.16s;
  font-family: 'Sora', sans-serif;
}
.goal-chip:hover { border-color: var(--ink); }
.goal-chip.on { border-color: var(--ink); color: var(--ink-soft); background: var(--ink-dim); }

.profile-save-row { display: flex; gap: 10px; margin-top: 18px; }

.profile-badges {
  margin-top: 16px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 18px;
}
.badges-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; margin-top: 12px; }
.badge-item {
  text-align: center;
  padding: 10px 4px;
  border-radius: 12px;
  background: var(--card);
  border: 1px solid var(--border);
  opacity: 0.35;
}
.badge-item.earned { opacity: 1; border-color: var(--teal-soft); background: var(--teal-dim); }
.badge-item .b-ico { font-size: 1.3rem; margin-bottom: 4px; display:block; }
.badge-item .b-lbl { font-size: 0.58rem; color: var(--text3); font-weight: 600; }
.badge-item.earned .b-lbl { color: var(--teal-soft); }

/* ═══════════════════════════════════════
   TRACKER SCREEN
═══════════════════════════════════════ */
.tracker-summary {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 18px;
}
.tsum-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 18px 16px;
}
.tsum-card.wide { grid-column: 1 / -1; display:flex; align-items:center; justify-content:space-between; }
.tsum-ico { width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:1rem;margin-bottom:10px;}
.tsum-num { font-family: 'JetBrains Mono', monospace; font-size: 1.5rem; font-weight: 600; color: var(--text); line-height:1; }
.tsum-lbl { font-size: 0.7rem; color: var(--text3); margin-top: 4px; font-weight: 600; }

.streak-flame { font-size: 2.2rem; }
.streak-text b { display:block; font-family:'Fraunces',serif; font-size:1.3rem; font-weight:600; color: var(--coral); }
.streak-text span { font-size: 0.72rem; color: var(--text3); }

.tracker-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 18px;
  margin-bottom: 14px;
}
.tracker-card-title {
  font-size: 0.74rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text3);
  margin-bottom: 14px;
  font-family: 'JetBrains Mono', monospace;
}

/* week calendar strip */
.week-strip { display: flex; gap: 6px; justify-content: space-between; }
.week-day { display:flex; flex-direction:column; align-items:center; gap:6px; flex: 1; }
.week-day-lbl { font-size: 0.62rem; color: var(--text3); font-weight: 700; text-transform: uppercase; }
.week-day-dot {
  width: 32px; height: 32px;
  border-radius: 9px;
  background: var(--card);
  border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.78rem;
  color: var(--text3);
}
.week-day-dot.done { background: var(--teal); border-color: var(--teal); color: #fff; }
.week-day-dot.today { border-color: var(--ink); color: var(--ink-soft); font-weight: 700; }

/* bar chart for minutes practiced */
.bar-chart { display: flex; align-items: flex-end; gap: 8px; height: 110px; margin-top: 6px; }
.bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6px; height: 100%; justify-content: flex-end; }
.bar-fill { width: 100%; max-width: 26px; border-radius: 6px 6px 3px 3px; background: var(--ink); transition: height 0.4s ease; min-height: 4px; }
.bar-col-lbl { font-size: 0.6rem; color: var(--text3); font-weight: 700; text-transform: uppercase; }

/* skill breakdown rows */
.skill-row { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
.skill-row:last-child { margin-bottom: 0; }
.skill-name { font-size: 0.8rem; font-weight: 600; color: var(--text); width: 110px; flex-shrink: 0; }
.skill-track { flex: 1; height: 8px; background: var(--card); border-radius: 6px; overflow: hidden; }
.skill-fill { height: 100%; border-radius: 6px; }
.skill-pct { font-size: 0.74rem; color: var(--text3); font-family: 'JetBrains Mono', monospace; width: 34px; text-align: right; flex-shrink: 0; }

/* ═══════════════════════════════════════
   TASKS SCREEN
═══════════════════════════════════════ */
.task-progress-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 18px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 16px;
}
.task-ring {
  width: 56px; height: 56px;
  border-radius: 50%;
  background: conic-gradient(var(--ink) 0deg, var(--border) 0deg);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.task-ring-inner {
  width: 42px; height: 42px;
  border-radius: 50%;
  background: var(--surface);
  display: flex; align-items: center; justify-content: center;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--ink-soft);
}
.task-progress-info b { display: block; font-size: 0.94rem; color: var(--text); margin-bottom: 2px; }
.task-progress-info span { font-size: 0.75rem; color: var(--text3); }

.task-add-row { display: flex; gap: 8px; margin-bottom: 16px; }

.task-list { display: flex; flex-direction: column; gap: 9px; }
.task-item {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 13px;
  padding: 13px 14px;
  display: flex;
  align-items: center;
  gap: 12px;
  transition: all 0.16s;
}
.task-item.done { opacity: 0.55; }
.task-check {
  width: 22px; height: 22px;
  border-radius: 7px;
  border: 1.5px solid var(--border2);
  background: var(--card);
  flex-shrink: 0;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.7rem;
  color: transparent;
  transition: all 0.16s;
}
.task-check.on { background: var(--teal); border-color: var(--teal); color: #fff; }
.task-item-text { flex: 1; font-size: 0.85rem; color: var(--text); }
.task-item.done .task-item-text { text-decoration: line-through; color: var(--text3); }
.task-item-tag {
  font-size: 0.62rem;
  font-weight: 700;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 5px;
  flex-shrink: 0;
  font-family: 'JetBrains Mono', monospace;
}
.task-del {
  background: none; border: none; color: var(--text3); cursor: pointer;
  font-size: 0.85rem; flex-shrink: 0; padding: 2px 4px; transition: color 0.15s;
}
.task-del:hover { color: var(--coral); }

.task-empty {
  text-align: center;
  padding: 40px 20px;
  color: var(--text3);
}
.task-empty .te-ico { font-size: 2.2rem; margin-bottom: 10px; display: block; }
.task-empty p { font-size: 0.84rem; }

.preset-task-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 18px; }
.preset-task-chip {
  background: var(--card);
  border: 1px solid var(--border);
  color: var(--text2);
  padding: 7px 12px;
  border-radius: 20px;
  font-size: 0.74rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.16s;
  font-family: 'Sora', sans-serif;
}
.preset-task-chip:hover { border-color: var(--ink); color: var(--ink-soft); background: var(--ink-dim); }

@media(max-width:380px) {
  .lang-grid { grid-template-columns: 1fr 1fr; }
  .cards-grid { gap: 9px; }
  .hero-headline { font-size: 1.85rem; }
  .quick-row { grid-template-columns: 1fr 1fr 1fr; }
  .badges-grid { grid-template-columns: repeat(4,1fr); }
}
</style>
</head>

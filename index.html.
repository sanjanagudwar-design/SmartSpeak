];
let curQ = 0, testScore = 0;

function initTest() { curQ = 0; testScore = 0; renderQ(); }

function renderQ() {
  document.getElementById('progFill').style.width = (curQ / qs.length * 100) + '%';
  if (curQ >= qs.length) { showResult(); return; }
  const q = qs[curQ];
  const letters = ['A','B','C','D'];
  document.getElementById('qArea').innerHTML = `
    <div class="q-card">
      <div class="q-num">Question ${curQ+1} of ${qs.length}</div>
      <div class="q-text">${q.q}</div>
      <div class="opts">
        ${q.opts.map((o,i) => `
          <button class="opt-btn" onclick="ansQ(this,${i},${q.ans})">
            <span class="opt-letter">${letters[i]}</span>${o}
          </button>`).join('')}
      </div>
    </div>`;
}

function ansQ(btn, sel, cor) {
  document.querySelectorAll('.opt-btn').forEach(b => b.disabled = true);
  if (sel === cor) { btn.classList.add('correct'); testScore++; confettiBurst(btn); }
  else {
    btn.classList.add('wrong');
    document.querySelectorAll('.opt-btn')[cor].classList.add('correct');
  }
  setTimeout(() => { curQ++; renderQ(); }, 900);
}

function showResult() {
  document.getElementById('progFill').style.width = '100%';

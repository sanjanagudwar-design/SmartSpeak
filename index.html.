// ═══════════════════════════════════════
// TRACKER
// ═══════════════════════════════════════
const dayLabels = ['M','T','W','T','F','S','S'];

function renderTracker() {
  document.getElementById('trkStreak').textContent = appData.streak + (appData.streak === 1 ? ' day' : ' days');
  document.getElementById('trkSessions').textContent = appData.sessions;
  document.getElementById('trkMinutes').textContent = appData.minutes;

  const todayI = todayIdx();
  document.getElementById('weekStrip').innerHTML = dayLabels.map((lbl,i) => {
    const done = appData.weekDone[i];
    const isToday = i === todayI;
    return `<div class="week-day">
      <div class="week-day-lbl">${lbl}</div>
      <div class="week-day-dot ${done ? 'done' : ''} ${isToday ? 'today' : ''}">${done ? '✓' : ''}</div>
    </div>`;
  }).join('');

  const maxMin = Math.max(10, ...appData.minutesByDay);
  document.getElementById('barChart').innerHTML = dayLabels.map((lbl,i) => {
    const mins = appData.minutesByDay[i] || 0;
    const h = Math.round((mins / maxMin) * 100);
    const isToday = i === todayI;
    return `<div class="bar-col">
      <div class="bar-fill" style="height:${h}%;background:${isToday ? 'var(--coral)' : 'var(--ink)'};"></div>
      <div class="bar-col-lbl">${lbl}</div>
    </div>`;
  }).join('');
}

// ═══════════════════════════════════════
// TASKS
// ═══════════════════════════════════════
function todayKey() {
  const d = new Date();
  return d.getFullYear() + '-' + (d.getMonth()+1) + '-' + d.getDate();
}

function renderTasks() {
  const today = todayKey();
  const todays = appData.tasks.filter(t => t.date === today);
  const list = document.getElementById('taskList');

  if (todays.length === 0) {
    list.innerHTML = `<div class="task-empty"><span class="te-ico">🗒️</span><p>No tasks yet — add one above or pick a quick suggestion.</p></div>`;
  } else {
    list.innerHTML = todays.map(t => `
      <div class="task-item ${t.done ? 'done' : ''}">
        <button class="task-check ${t.done ? 'on' : ''}" onclick="toggleTask('${t.id}')">${t.done ? '✓' : ''}</button>
        <div class="task-item-text">${escapeHtml(t.text)}</div>
        <button class="task-del" onclick="deleteTask('${t.id}')" title="Remove">✕</button>
      </div>`).join('');
  }

  const doneCount = todays.filter(t => t.done).length;
  const total = todays.length;
  const pct = total ? Math.round((doneCount/total)*100) : 0;
  document.getElementById('taskRing').style.background = `conic-gradient(var(--ink) ${pct*3.6}deg, var(--border) ${pct*3.6}deg)`;
  document.getElementById('taskRingTxt').textContent = doneCount + '/' + total;
  document.getElementById('taskProgressLabel').textContent = total === 0
    ? 'No tasks yet today'
    : (doneCount === total ? 'All tasks done! 🎉' : doneCount + ' of ' + total + ' tasks complete');

  if (total > 0 && doneCount === total) appData.badges.task = true;
  saveData();
  refreshDashboardQuickStats();
}

function escapeHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function addTask() {
  const inp = document.getElementById('taskInput');
  const text = inp.value.trim();
  if (!text) return;
  inp.value = '';
  appData.tasks.push({ id: 't' + Date.now(), text, date: todayKey(), done: false });
  saveData();
  renderTasks();
}

function addPresetTask(text) {
  const today = todayKey();
  const exists = appData.tasks.some(t => t.date === today && t.text === text);
  if (exists) return;
  appData.tasks.push({ id: 't' + Date.now() + Math.random().toString(36).slice(2,6), text, date: today, done: false });
  saveData();
  renderTasks();
}

function toggleTask(id) {
  const t = appData.tasks.find(x => x.id === id);
  if (t) { t.done = !t.done; saveData(); renderTasks(); confettiBurst(document.getElementById('taskList')); }
}

function deleteTask(id) {
  appData.tasks = appData.tasks.filter(x => x.id !== id);
  saveData();
  renderTasks();
}

// initial sync on load
refreshDashboardQuickStats();

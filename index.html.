// ═══════════════════════════════════════
// TTS
// ═══════════════════════════════════════
function speakText(text, onEnd) {
  if (!window.speechSynthesis) return;
  window.speechSynthesis.cancel();
  const utt = new SpeechSynthesisUtterance(text.substring(0, 300));
  utt.rate = 0.92; utt.pitch = 1; utt.volume = 1;
  if (lang === 'Hindi' || lang === 'Marathi') utt.lang = 'hi-IN';
  else if (lang === 'Tamil') utt.lang = 'ta-IN';
  else if (lang === 'Telugu') utt.lang = 'te-IN';
  else if (lang === 'Bengali') utt.lang = 'bn-IN';
  else utt.lang = 'en-IN';
  utt.onend = () => { if (onEnd) onEnd(); };
  window.speechSynthesis.speak(utt);
}

function showAiSpeaking(id) { const el = document.getElementById(id); if(el) el.classList.add('visible'); }
function hideAiSpeaking(id) { const el = document.getElementById(id); if(el) el.classList.remove('visible'); }

// ═══════════════════════════════════════
// GEMINI API
// ═══════════════════════════════════════
async function callGemini(prompt) {
  const r = await fetch(GEMINI_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      contents: [{ role: 'user', parts: [{ text: prompt }] }],
      generationConfig: { maxOutputTokens: 300, temperature: 0.7 }
    })
  });
  if (!r.ok) throw new Error('API error');
  const d = await r.json();
  return d.candidates[0].content.parts[0].text;
}


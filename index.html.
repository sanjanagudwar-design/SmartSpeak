// ═══════════════════════════════════════
// FUN: CONFETTI BURST
// ═══════════════════════════════════════
const confettiColors = ['#5B7FFF','#2FC4A3','#FF6B5B','#9B7BFF'];
function confettiBurst(el) {
  const rect = (el && el.getBoundingClientRect) ? el.getBoundingClientRect() : {left:window.innerWidth/2,top:window.innerHeight/2};
  const cx = rect.left + (rect.width||0)/2;
  const cy = rect.top + (rect.height||0)/2;
  const burst = document.createElement('div');
  burst.className = 'confetti-burst';
  burst.style.left = cx + 'px';
  burst.style.top = cy + 'px';
  document.body.appendChild(burst);
  for (let i = 0; i < 12; i++) {
    const piece = document.createElement('div');
    piece.className = 'confetti-piece';
    piece.style.background = confettiColors[i % confettiColors.length];
    piece.style.left = (Math.random() * 80 - 40) + 'px';
    piece.style.animationDelay = (Math.random() * 0.3) + 's';
    piece.style.animationDuration = (0.8 + Math.random() * 0.6) + 's';
    burst.appendChild(piece);
  }
  setTimeout(() => burst.remove(), 1800);
}

// ═══════════════════════════════════════
// PRONUNCIATION
// ═══════════════════════════════════════
function toggleMic() {
  if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
    alert('Please use Chrome browser for voice features!'); return;
  }
  if (isListening) { recognition.stop(); return; }
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  recognition = new SR();
  recognition.lang = 'en-IN';
  recognition.continuous = false;
  recognition.interimResults = true;
  recognition.onstart = () => {
    isListening = true;
    document.getElementById('bigMic').classList.add('on');
    document.getElementById('bigMic').textContent = '⏹';
    document.getElementById('micZone').classList.add('on');
    document.getElementById('micStatus').textContent = '🔴 Listening… speak now!';
  };
  recognition.onresult = (e) => {
    const t = Array.from(e.results).map(r => r[0].transcript).join('');
    document.getElementById('micOutput').textContent = '"' + t + '"';
  };
  recognition.onend = () => {
    isListening = false;
    document.getElementById('bigMic').classList.remove('on');
    document.getElementById('bigMic').textContent = '🎤';
    document.getElementById('micZone').classList.remove('on');
    document.getElementById('micStatus').textContent = 'Tap the mic and speak in English';
    const t = document.getElementById('micOutput').textContent.replace(/"/g,'').trim();
    if (t) analyzePron(t);
  };
  recognition.start();
}

async function analyzePron(text) {
  document.getElementById('pronResult').classList.remove('hidden');
  document.getElementById('fbOriginal').textContent = text;
  document.getElementById('fbText').innerHTML = '<div class="loading-dots"><div class="dot-row"><span></span><span></span><span></span></div> Analysing your English…</div>';
  const sc = Math.floor(Math.random() * 3) + 7;
  document.getElementById('scoreVal').textContent = sc + '/10';
  document.getElementById('scoreLabel').textContent = sc >= 9 ? 'Excellent! 🔥' : sc >= 7 ? 'Great effort! 👏' : 'Keep going! 💪';
  const deg = Math.round((sc / 10) * 360);
  document.getElementById('scoreRing').style.background = `conic-gradient(var(--teal-soft) ${deg}deg, var(--border) ${deg}deg)`;
  logSession('pronunciation', 2);
  const prompt = `You are a friendly English coach for Indian students. Student spoke: "${text}". Give feedback in ${lang}. Student level: ${level}. Include: 1) What was correct 2) Grammar/pronunciation mistakes 3) Better way to say it 4) One tip. Be warm, encouraging, under 120 words.`;
  try {
    const res = await callGemini(prompt);
    document.getElementById('fbText').textContent = res;
    showAiSpeaking('aiSpeaking');
    speakText(res, () => hideAiSpeaking('aiSpeaking'));
  } catch(e) {
    document.getElementById('fbText').textContent = `Bahut achha! "${text}" — aapne achha bola. Grammar theek hai, pronunciation practice karte raho. Confidence sabse important hai! 💪`;
  }
}

function resetPron() {

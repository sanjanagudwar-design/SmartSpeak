// ═══════════════════════════════════════
// SESSION LOGGING — feeds Tracker + Profile + badges
// ═══════════════════════════════════════
function todayIdx() {
  // Mon=0 ... Sun=6
  const d = new Date().getDay();
  return d === 0 ? 6 : d - 1;
}

function logSession(kind, minutes) {
  appData.sessions += 1;
  appData.minutes += minutes;
  const idx = todayIdx();
  appData.weekDone[idx] = true;
  appData.minutesByDay[idx] = (appData.minutesByDay[idx] || 0) + minutes;

  if (appData.sessions === 1) appData.badges.first = true;
  if (appData.streak >= 3) appData.badges['3day'] = true;
  if (appData.streak >= 7) appData.badges['7day'] = true;

  saveData();
  refreshDashboardQuickStats();
}

function refreshDashboardQuickStats() {
  const nameEl = document.getElementById('qiProfileName');
  if (nameEl) nameEl.textContent = appData.name ? appData.name.split(' ')[0] : 'Set up';
  const streakEl = document.getElementById('qiStreak');
  if (streakEl) streakEl.textContent = appData.streak + ' day streak';
  const tasksEl = document.getElementById('qiTasks');
  if (tasksEl) {
    const today = todayKey();
    const todays = appData.tasks.filter(t => t.date === today);
    const doneCount = todays.filter(t => t.done).length;
    tasksEl.textContent = doneCount + '/' + todays.length + ' today';
  }
}


function addMsg(cid, text, type) {
  const c = document.getElementById(cid);
  const id = 'msg' + (++msgId);
  const av = type === 'ai' ? '🤖' : '👤';
  c.innerHTML += `<div class="msg ${type}" id="${id}"><div class="msg-av">${av}</div><div class="msg-bub">${text}</div></div>`;
  c.scrollTop = c.scrollHeight;
  return id;
}

function updateMsg(id, text) {
  const el = document.getElementById(id);
  if (el) {
    el.querySelector('.msg-bub').textContent = text;
    const c = el.closest('.chat-box');
    if (c) c.scrollTop = c.scrollHeight;
  }
}


// ═══════════════════════════════════════
const qs = [
  { q: 'Choose the correct sentence:', opts: ['She go to school every day.','She goes to school every day.','She going to school.','She goed to school.'], ans: 1 },
  { q: 'Fill in: I _____ watching TV when you called.', opts: ['am','was','is','were'], ans: 1 },
  { q: 'Which word means "happy"?', opts: ['Sad','Angry','Joyful','Tired'], ans: 2 },
  { q: 'Choose the correct question:', opts: ['Where you are going?','Where are you going?','Where going you are?','You are where going?'], ans: 1 },
